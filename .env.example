# Database — Supabase (Project Settings → Database → Connection string)
# Copy the pooler hostname exactly from your dashboard (aws-0 vs aws-1 differs per project).
# URL-encode special characters in the password (# → %23, @ → %40, etc.)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# Auth
JWT_SECRET="change-me-min-32-chars"
NEXTAUTH_SECRET="change-me-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# App URL (email links, OAuth callbacks). On Vercel, set to https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Registration (Vercel: set DATABASE_URL, then deploy runs prisma migrate deploy)
# USE_MOCK_EMAIL=true auto-verifies email when SMTP is not configured
USE_MOCK_EMAIL="true"
# REQUIRE_ADMIN_APPROVAL=true blocks login until an admin approves (no UI yet)
REQUIRE_ADMIN_APPROVAL="false"
# SKIP_EMAIL_VERIFICATION=true forces emailVerified on signup (overrides mock check if set)
# SKIP_EMAIL_VERIFICATION="false"

# Google OAuth (optional — enables "Sign in with Google" on login/signup)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (optional; omit SMTP_* when USE_MOCK_EMAIL=true above)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# UploadThing (media uploads)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Pusher (realtime) — also set NEXT_PUBLIC_* for client subscriptions
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Upstash Redis (rate limiting / caching)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OneSignal (push notifications, optional)
ONESIGNAL_APP_ID=""
ONESIGNAL_API_KEY=""
