# Database (Neon, Supabase, or other Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth
JWT_SECRET="change-me-min-32-chars"
NEXTAUTH_SECRET="change-me-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# App URL (email links, OAuth callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (optional; omit SMTP_* or set USE_MOCK_EMAIL=true for dev)
USE_MOCK_EMAIL="true"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# UploadThing (media uploads)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Pusher (realtime)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# Upstash Redis (rate limiting / caching)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OneSignal (push notifications, optional)
ONESIGNAL_APP_ID=""
ONESIGNAL_API_KEY=""
